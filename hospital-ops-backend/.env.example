# Google Cloud Project details
PROJECT_ID=your-gcp-project-id
REGION=us-central1

# AlloyDB Configurations (Inventory Agent)
CLUSTER_ID=hospital-ops-cluster
INSTANCE_ID=hospital-ops-instance
DB_USER=postgres
DB_PASS=hospital-ops-pass
DB_NAME=postgres

# Gemini API (Vision Agent)
GEMINI_API_KEY=your_gemini_api_key_here

# Networking
# When running locally with Docker Compose, the Vision agent will use this URL to talk to Inventory:
INVENTORY_AGENT_URL=http://inventory-agent:8080